# listmonk-analytics — example environment variables
# Copy this file to .env (or set these vars in your deployment environment).
# Never commit a .env file with real credentials.

# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------

# Postgres connection string for the listmonk database.
# Use the read-only role created by setup/readonly-role.sql.
# Never use listmonk's own superuser/admin credentials here.
DATABASE_URL=postgresql://analytics_ro:CHANGE_ME@localhost:5432/listmonk

# ------------------------------------------------------------------
# Optional — server
# ------------------------------------------------------------------

# Address and port to listen on. Takes precedence over PORT.
# Default: :8080
# LISTEN_ADDR=0.0.0.0:8080

# Port only (used when LISTEN_ADDR is not set).
# Railway sets this automatically at runtime.
# Default: 8080
# PORT=8080

# Public base URL (e.g. https://analytics.example.com).
# Not required for normal operation.
# ROOT_URL=

# ------------------------------------------------------------------
# Optional — dashboard auth (strongly recommended for production)
# ------------------------------------------------------------------

# HTTP basic auth credentials. Both must be set to enable auth.
# Required to access the subscriber engagement view (which exposes
# subscriber email/name). Without auth, that endpoint is blocked.
# DASHBOARD_USER=admin
# DASHBOARD_PASS=change-me-strong-password

# ------------------------------------------------------------------
# Optional — analytics tuning
# ------------------------------------------------------------------

# Lookback window in days for subscriber engagement scoring.
# Must be a positive integer. Default: 90
# ENGAGED_WINDOW_DAYS=90
